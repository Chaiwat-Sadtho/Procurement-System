# @keyv/redis (Redis cache store, Phase 8) needs keyv@^5, while eslint's
# transitive flat-cache@4 pins keyv@^4. Both majors coexist nested in the tree;
# npm v7+ strict peer resolution rejects this. legacy-peer-deps lets the install
# proceed (npm v6 nesting behavior). Kept in .npmrc so npm install / CI npm ci stay consistent.
legacy-peer-deps=true
