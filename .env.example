# Database
# DB_HOST=localhost สำหรับรัน backend นอก Docker (npm run start:dev)
# เมื่อรันผ่าน docker compose ค่า DB_HOST จะถูก override เป็น "postgres" อัตโนมัติ
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=procurement_user
DB_PASSWORD=procurement_pass
DB_NAME=procurement_db

# JWT
JWT_SECRET=change-this-to-a-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development

# CORS — allowlist ของ browser origin (คั่นด้วย comma ได้หลายค่า เช่น https://a.com,https://b.com)
# - ไม่ตั้งค่า + NODE_ENV != production → default http://localhost:5173 (Vite dev)
# - docker compose: ตั้งเป็น http://localhost:8080 (origin ของ frontend nginx)
# - fail-closed: NODE_ENV=production แล้วไม่ตั้งค่านี้ → backend refuse boot (กัน CORS เปิดโล่ง)
CORS_ORIGIN=http://localhost:8080

# Redis cache (Phase 8) — optional: ถ้าไม่มี Redis แอป graceful-degrade ยิง DB ตรง
# REDIS_HOST=localhost สำหรับรัน backend นอก Docker; ผ่าน docker compose จะ override เป็น "redis" อัตโนมัติ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
